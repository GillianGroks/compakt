{
  "name": "compakt",
  "version": "1.0.1",
  "type": "module",
  "description": "Chunked context compaction plugin for local LLMs.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "compakt": "cli.mjs"
  },
  "files": [
    "dist/",
    "cli.mjs",
    "openclaw.plugin.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "openclaw": {
    "extensions": "dist/index.js",
    "compat": {
      "pluginApi": ">=2026.4.10"
    },
    "build": {
      "openclawVersion": "2026.4.10"
    }
  },
  "author": "Gillian Groks",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gilliangroks/compakt.git"
  },
  "bugs": {
    "url": "https://github.com/gilliangroks/compakt/issues"
  },
  "homepage": "https://github.com/gilliangroks/compakt#readme",
  "keywords": [
    "openclaw",
    "plugin",
    "compaction",
    "context",
    "llm"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
